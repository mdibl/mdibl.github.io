{
  "name": "Intro to R & RStudio",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "DISABLE_AUTH": "true"
  },
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "RStudio",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "echo 'setwd(\"/workspaces/mdibl.github.io/docs/introR\")' >> /home/rstudio/.Rprofile",
  "postStartCommand": "/init &",
  "workspaceFolder": "/workspaces/mdibl.github.io/docs/introR"
}
