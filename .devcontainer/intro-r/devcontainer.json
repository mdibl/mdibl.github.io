{
  "name": "Intro to R & RStudio",
  "image": "ghcr.io/rocker-org/devcontainer/tidyverse:4",
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/rstudio-server:latest": {}
  },
  "postAttachCommand": "sudo rstudio-server start",
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": { "label": "RStudio IDE", "onAutoForward": "openBrowser" }
  },
  "workspaceFolder": "/workspaces/mdibl.github.io/docs/introR"
}